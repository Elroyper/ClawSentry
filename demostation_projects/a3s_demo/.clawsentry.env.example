# ClawSentry demo env-first template
# Copy to .clawsentry.env.local for local-only values, then pass --env-file explicitly.
# Do not commit real tokens or provider API keys.
CS_FRAMEWORK=a3s-code
CS_ENABLED_FRAMEWORKS=a3s-code
CS_MODE=normal
CS_PRESET=medium
CS_LLM_PROVIDER=
CS_LLM_MODEL=
CS_LLM_BASE_URL=
# Set CS_LLM_API_KEY in local env/secrets manager when enabling L2/L3.
CS_L2_ENABLED=false
CS_L3_ENABLED=false
CS_LLM_TOKEN_BUDGET_ENABLED=false
CS_LLM_DAILY_TOKEN_BUDGET=0
CS_DEFER_BRIDGE_ENABLED=true
CS_DEFER_TIMEOUT_ACTION=block
