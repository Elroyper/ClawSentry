# ClawSentry Gateway — systemd environment variables
# Copy this file to /etc/clawsentry/gateway.env and customize as needed.

# --- Authentication ---
# REQUIRED: Set a strong random token (>= 32 chars recommended)
CS_AUTH_TOKEN=changeme-replace-with-a-strong-random-token

# --- Network ---
# CS_HTTP_HOST=127.0.0.1
# CS_HTTP_PORT=8080

# --- Database ---
# CS_TRAJECTORY_DB_PATH=/var/lib/clawsentry/trajectory.db

# --- Risk thresholds ---
# CS_THRESHOLD_MEDIUM=0.8
# CS_THRESHOLD_HIGH=1.5
# CS_THRESHOLD_CRITICAL=2.2

# --- Scoring weights ---
# CS_COMPOSITE_WEIGHT_MAX_D123=0.4
# CS_COMPOSITE_WEIGHT_D4=0.25
# CS_COMPOSITE_WEIGHT_D5=0.15
# CS_D6_INJECTION_MULTIPLIER=0.5

# --- L2 / L3 semantic analysis ---
# CS_LLM_PROVIDER=anthropic
# CS_LLM_API_KEY=sk-ant-...
# CS_L2_BUDGET_MS=5000

# --- D4 frequency detection ---
# CS_D4_FREQ_ENABLED=true
# CS_D4_FREQ_BURST_COUNT=10
# CS_D4_FREQ_BURST_WINDOW_S=5.0
# CS_D4_FREQ_REPETITIVE_COUNT=20
# CS_D4_FREQ_REPETITIVE_WINDOW_S=60.0
# CS_D4_FREQ_RATE_LIMIT_PER_MIN=60

# --- External content safety ---
# CS_EXTERNAL_CONTENT_D6_BOOST=0.3
# CS_EXTERNAL_CONTENT_POST_ACTION_MULTIPLIER=1.3

# --- Post-action analysis ---
# CS_POST_ACTION_EMERGENCY=0.9
# CS_POST_ACTION_ESCALATE=0.6
# CS_POST_ACTION_MONITOR=0.3

# --- Self-evolving patterns ---
# CS_EVOLVING_ENABLED=false
# CS_EVOLVED_PATTERNS_PATH=

# --- OpenClaw integration ---
# CS_OPENCLAW_TOKEN=
# CS_OPENCLAW_WEBHOOK_SECRET=

# --- Rate limiting ---
# CS_RATE_LIMIT_PER_MINUTE=300

# --- Prometheus / Metrics ---
# CS_METRICS_AUTH=false
# CS_LLM_DAILY_BUDGET_USD=0

# --- DEFER configuration ---
# CS_DEFER_TIMEOUT_S=300
# CS_DEFER_TIMEOUT_ACTION=block
# CS_DEFER_BRIDGE_ENABLED=false
